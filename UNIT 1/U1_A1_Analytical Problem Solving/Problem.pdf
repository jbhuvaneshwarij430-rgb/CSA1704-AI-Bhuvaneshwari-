# --- QUESTION : # Water Jug Problem (4-gallon and 3-gallon)
jug4 = 0
jug3 = 0

print("Initial State:")
print("4-Gallon Jug =", jug4, "3-Gallon Jug =", jug3)

# Step 1
jug3 = 3
print("\nStep 1: Fill the 3-gallon jug")
print("4-Gallon Jug =", jug4, "3-Gallon Jug =", jug3)

# Step 2
jug4 = jug3
jug3 = 0
print("\nStep 2: Pour 3-gallon jug into 4-gallon jug")
print("4-Gallon Jug =", jug4, "3-Gallon Jug =", jug3)

# Step 3
jug3 = 3
print("\nStep 3: Fill the 3-gallon jug again")
print("4-Gallon Jug =", jug4, "3-Gallon Jug =", jug3)

# Step 4
space = 4 - jug4
jug4 = 4
jug3 = jug3 - space
print("\nStep 4: Pour water into 4-gallon jug until it is full")
print("4-Gallon Jug =", jug4, "3-Gallon Jug =", jug3)

# Step 5
jug4 = 0
print("\nStep 5: Empty the 4-gallon jug")
print("4-Gallon Jug =", jug4, "3-Gallon Jug =", jug3)

# Step 6
jug4 = jug3
jug3 = 0
print("\nStep 6: Pour remaining water into 4-gallon jug")
print("4-Gallon Jug =", jug4, "3-Gallon Jug =", jug3)

print("\nGoal Achieved!")
print("Exactly", jug4, "gallons of water are in the 4-gallon jug.") ---
